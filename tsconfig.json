{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["shared/*"],
      "@src/*": ["src/*"]
    },
    "types": ["vitest/globals"],
    "allowImportingTsExtensions": true,
    "noEmit": true
  },
  "include": [
    "shared/**/*.ts",
    "src/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}